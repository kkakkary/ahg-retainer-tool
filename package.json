{
  "name": "ahg-retainer-tool",
  "version": "1.3.4",
  "description": "AHG Retainer Agreement Generator — Law Office of Andrew H. Griffin, III, APC",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently \"webpack serve --config webpack.config.js\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "build": "webpack --config webpack.config.js && electron-builder",
    "publish": "dotenv -- sh -c 'GH_TOKEN=$(gh auth token) webpack --config webpack.config.js && electron-builder --publish always'",
    "publish:ci": "webpack --config webpack.config.js && electron-builder --publish always",
    "dev": "concurrently \"webpack serve --config webpack.config.js\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "postinstall": "node scripts/rename-electron.js"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "docxtemplater": "^3.68.3",
    "electron-updater": "^6.8.3",
    "libreoffice-convert": "^1.8.1",
    "pdfjs-dist": "^5.6.205",
    "pizzip": "^3.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.5.4",
    "postcss-loader": "^7.3.4",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.4.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  },
  "build": {
    "asar": true,
    "appId": "com.kkai.ahg-retainer",
    "productName": "AHG Document Creation Tool",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "artifactName": "AHG-Document-Creation-Tool-${version}-${arch}.${ext}",
    "mac": {
      "hardenedRuntime": true,
      "notarize": false,
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "category": "public.app-category.business",
      "icon": "assets/icon.icns"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "!node_modules/@napi-rs/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "kkakkary",
      "repo": "ahg-retainer-tool",
      "releaseType": "release"
    }
  }
}
